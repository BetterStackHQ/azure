{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "servicePrincipalObjectId": {
      "type": "string",
      "metadata": {
        "description": "Object ID of the Better Stack service principal in your tenant (provided by Better Stack after consent)."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the EventHub and Vector container. Deploy this template once per additional region where you have resources whose logs you want forwarded."
      }
    },
    "betterStackSourceToken": {
      "type": "secureString",
      "metadata": {
        "description": "Better Stack source token for log ingestion."
      }
    },
    "betterStackIngestingHost": {
      "type": "string",
      "metadata": {
        "description": "Better Stack log ingestion endpoint."
      }
    },
    "betterStackSourceId": {
      "type": "string",
      "metadata": {
        "description": "Better Stack source ID (e.g. s12345). Must match the value used in the original subscription-level deployment."
      }
    }
  },
  "variables": {
    "eventHubName": "logs",
    "namespaceName": "[concat('betterstack-', parameters('betterStackSourceId'), '-', parameters('location'))]",
    "eventHubsDataOwnerRoleId": "f526a384-b230-433a-b45c-95f59c4a2dec"
  },
  "resources": [
    {
      "type": "Microsoft.EventHub/namespaces",
      "apiVersion": "2024-01-01",
      "name": "[variables('namespaceName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard",
        "tier": "Standard",
        "capacity": 1
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.EventHub/namespaces/{0}', variables('namespaceName'))]",
      "name": "[guid(resourceId('Microsoft.EventHub/namespaces', variables('namespaceName')), parameters('servicePrincipalObjectId'), variables('eventHubsDataOwnerRoleId'))]",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('namespaceName'))]"
      ],
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('eventHubsDataOwnerRoleId'))]",
        "principalId": "[parameters('servicePrincipalObjectId')]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs",
      "apiVersion": "2024-01-01",
      "name": "[concat(variables('namespaceName'), '/', variables('eventHubName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('namespaceName'))]"
      ],
      "properties": {
        "messageRetentionInDays": 1,
        "partitionCount": 4
      }
    },
    {
      "type": "Microsoft.EventHub/namespaces/eventhubs/consumergroups",
      "apiVersion": "2024-01-01",
      "name": "[concat(variables('namespaceName'), '/', variables('eventHubName'), '/vector-consumer-group')]",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs', variables('namespaceName'), variables('eventHubName'))]"
      ]
    },
    {
      "type": "Microsoft.EventHub/namespaces/authorizationRules",
      "apiVersion": "2024-01-01",
      "name": "[concat(variables('namespaceName'), '/DiagnosticSettingsSend')]",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('namespaceName'))]"
      ],
      "properties": {
        "rights": [
          "Send"
        ]
      }
    },
    {
      "type": "Microsoft.EventHub/namespaces/authorizationRules",
      "apiVersion": "2024-01-01",
      "name": "[concat(variables('namespaceName'), '/VectorListen')]",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('namespaceName'))]"
      ],
      "properties": {
        "rights": [
          "Listen"
        ]
      }
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[concat('betterstack-vector-', parameters('betterStackSourceId'), '-', parameters('location'))]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces/authorizationRules', variables('namespaceName'), 'VectorListen')]",
        "[resourceId('Microsoft.EventHub/namespaces/eventhubs/consumergroups', variables('namespaceName'), variables('eventHubName'), 'vector-consumer-group')]"
      ],
      "properties": {
        "containers": [
          {
            "name": "vector",
            "properties": {
              "image": "ghcr.io/vectordotdev/vector:latest-debian",
              "resources": {
                "requests": {
                  "cpu": 1,
                  "memoryInGB": 1
                }
              },
              "command": [
                "/bin/sh",
                "-c",
                "cat > /etc/vector/vector.toml << 'VECTORCFG'\n[sources.azure_event_hub]\ntype = \"kafka\"\nbootstrap_servers = \"${EVENTHUB_NAMESPACE_FQDN}:9093\"\ngroup_id = \"vector-consumer-group\"\ntopics = [\"${EVENTHUB_NAME}\"]\nsasl.enabled = true\nsasl.mechanism = \"PLAIN\"\nsasl.username = \"$$ConnectionString\"\nsasl.password = \"${EVENTHUB_CONNECTION_STRING}\"\ntls.enabled = true\ndecoding.codec = \"json\"\n\n[transforms.rename_timestamp]\ntype = \"remap\"\ninputs = [\"azure_event_hub\"]\nsource = \".dt = del(.timestamp)\"\n\n[sinks.betterstack]\ntype = \"http\"\ninputs = [\"rename_timestamp\"]\nuri = \"https://${BETTERSTACK_INGESTING_HOST}\"\nmethod = \"post\"\nencoding.codec = \"json\"\ncompression = \"gzip\"\nauth.strategy = \"bearer\"\nauth.token = \"${BETTERSTACK_SOURCE_TOKEN}\"\nbatch.max_bytes = 1048576\nbatch.timeout_secs = 1\nrequest.retry_attempts = 3\nrequest.timeout_secs = 30\nVECTORCFG\nexec vector --config /etc/vector/vector.toml"
              ],
              "environmentVariables": [
                {
                  "name": "EVENTHUB_CONNECTION_STRING",
                  "secureValue": "[listKeys(resourceId('Microsoft.EventHub/namespaces/authorizationRules', variables('namespaceName'), 'VectorListen'), '2024-01-01').primaryConnectionString]"
                },
                {
                  "name": "BETTERSTACK_SOURCE_TOKEN",
                  "secureValue": "[parameters('betterStackSourceToken')]"
                },
                {
                  "name": "EVENTHUB_NAMESPACE_FQDN",
                  "value": "[concat(variables('namespaceName'), '.servicebus.windows.net')]"
                },
                {
                  "name": "EVENTHUB_NAME",
                  "value": "[variables('eventHubName')]"
                },
                {
                  "name": "BETTERSTACK_INGESTING_HOST",
                  "value": "[parameters('betterStackIngestingHost')]"
                }
              ]
            }
          }
        ],
        "osType": "Linux",
        "restartPolicy": "Always"
      }
    }
  ],
  "outputs": {
    "eventHubNamespaceName": {
      "type": "string",
      "value": "[variables('namespaceName')]"
    },
    "eventHubName": {
      "type": "string",
      "value": "[variables('eventHubName')]"
    }
  }
}
